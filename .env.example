STRIPE_PRICE_FUND_SUITE=""

# Telegram Bot (whale alerts)
TELEGRAM_BOT_TOKEN=""

# Discord webhooks
DISCORD_WEBHOOK_URL=""

# Trigger.dev
TRIGGER_API_KEY=""

# PostgreSQL (Supabase or local Docker)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/govwatch"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/govwatch"

# Supabase (for realtime + storage)
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# OpenRouter (LLM provider for summaries + digest)
# Default model: google/gemini-2.5-flash. Override via OPENROUTER_MODEL if needed.
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="google/gemini-2.5-flash"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""

# Resend (email + newsletter)
RESEND_API_KEY=""
EMAIL_FROM="DAO Sentinel <noreply@daosentinel.xyz>"

# Telegram Bot (whale alerts) — create via @BotFather, then hit
# /api/telegram/setup once to register the webhook. No-op until TOKEN is set.
TELEGRAM_BOT_TOKEN=""
TELEGRAM_BOT_USERNAME=""        # the bot's @username without the @ (for deep links)
TELEGRAM_WEBHOOK_SECRET=""      # REQUIRED once the bot token is set — webhook fails closed without it

# Discord webhooks
DISCORD_WEBHOOK_URL=""

# Trigger.dev
TRIGGER_API_KEY=""
TRIGGER_PROJECT_ID=""

# Alchemy (ENS resolution + on-chain calls)
ALCHEMY_API_KEY=""

# Tally (on-chain Governor proposals: Compound, Uniswap on-chain, ENS, dYdX, …)
# Without a key, sync-tally is a no-op — leave empty until you have one.
TALLY_API_KEY=""

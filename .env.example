# PostgreSQL (Supabase or local Docker)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/govwatch"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/govwatch"

# Supabase (for realtime + storage)
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# OpenRouter (LLM provider for summaries + digest)
# Default model: google/gemini-2.5-flash. Override via OPENROUTER_MODEL if needed.
OPENROUTER_API_KEY=""
